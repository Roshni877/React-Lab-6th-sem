import React, { useState } from 'react';

function Home() {
  const [activeSection, setActiveSection] = useState('overview');

  return (
    <div className="container">
      <h2>Home Page</h2>
      <div style={{ display: 'flex', marginBottom: '20px' }}>
        <button onClick={() => setActiveSection('overview')} style={{ marginRight: '10px' }}>
          Overview
        </button>
        <button onClick={() => setActiveSection('services')} style={{ marginRight: '10px' }}>
          Services
        </button>
        <button onClick={() => setActiveSection('news')}>
          News
        </button>
      </div>

      {activeSection === 'overview' && (
        <div className="section">
          <h3>Overview</h3>
          <p>Welcome to our website! We provide modern solutions for your digital needs.</p>
        </div>
      )}
      {activeSection === 'services' && (
        <div className="section">
          <h3>Services</h3>
          <p>We offer web development, mobile app development, and cloud solutions.</p>
        </div>
      )}
      {activeSection === 'news' && (
        <div className="section">
          <h3>Latest News</h3>
          <p>Stay tuned for updates on our upcoming projects and collaborations.</p>
        </div>
      )}
    </div>
  );
}

export default Home;


